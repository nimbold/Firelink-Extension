{
  "manifest_version": 3,
  "name": "Firelink Companion",
  "version": "1.0.10",
  "description": "Capture downloads and links directly to Firelink download manager.",
  "permissions": [
    "downloads",
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:6412/*",
    "http://127.0.0.1:6413/*",
    "http://127.0.0.1:6414/*",
    "http://127.0.0.1:6415/*",
    "http://127.0.0.1:6416/*",
    "http://127.0.0.1:6417/*",
    "http://127.0.0.1:6418/*",
    "http://127.0.0.1:6419/*",
    "http://127.0.0.1:6420/*",
    "http://127.0.0.1:6421/*",
    "http://127.0.0.1:6422/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Firelink Companion"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firelink@nimbold.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
