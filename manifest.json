{
  "manifest_version": 3,
  "name": "Firelink Companion",
  "version": "1.0.13",
  "description": "Capture downloads and links directly to Firelink download manager.",
  "permissions": [
    "downloads",
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:23522/*",
    "http://127.0.0.1:23523/*",
    "http://127.0.0.1:23524/*",
    "http://127.0.0.1:23525/*",
    "http://127.0.0.1:23526/*",
    "http://127.0.0.1:23527/*",
    "http://127.0.0.1:23528/*",
    "http://127.0.0.1:23529/*",
    "http://127.0.0.1:23530/*",
    "http://127.0.0.1:23531/*"
  ],
  "background": {
    "scripts": ["protocol.js", "background.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "64": "icons/icon-64.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Firelink Companion"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firelink@nimbold.github.io",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
